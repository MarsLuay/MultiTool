<Window x:Class="AutoClicker.App.Views.MacroNamePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Macro"
        Width="430"
        Height="340"
        MinWidth="360"
        MinHeight="280"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
  <Border Margin="12"
          Padding="0"
          Background="{DynamicResource SurfaceBrush}"
          BorderBrush="{DynamicResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="8">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock FontSize="16"
               FontWeight="SemiBold"
               Text="Name this macro" />

    <TextBlock Grid.Row="1"
               Margin="0,8,0,0"
               Text="Type the macro name below. Press Save and it will go straight into the Macros folder next to MultiTool.exe."
               TextWrapping="Wrap" />

    <Border Grid.Row="2"
            Margin="0,14,0,0"
            Padding="12"
            Background="{DynamicResource SurfaceAltBrush}"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="2"
            CornerRadius="8">
      <StackPanel>
      <TextBlock FontWeight="SemiBold"
                 Text="Macro name" />
      <TextBox x:Name="NameTextBox"
               Margin="0,8,0,0"
               Height="40"
               Padding="12,8"
               FontSize="15"
               VerticalContentAlignment="Center"
               Background="{DynamicResource ControlBackgroundBrush}"
               BorderBrush="{DynamicResource AccentBrush}"
               BorderThickness="2"
               ToolTip="Enter the macro name here."
               TextChanged="NameTextBox_OnTextChanged" />
      <TextBlock Margin="0,10,0,0"
                 FontWeight="SemiBold"
                 Text="Will save to" />
      <TextBlock x:Name="SaveFolderTextBlock"
                 Margin="0,4,0,0"
                 MaxWidth="340"
                 Foreground="{DynamicResource MutedTextBrush}"
                 TextWrapping="Wrap" />
      <TextBlock x:Name="SaveFilePreviewTextBlock"
                 Margin="0,4,0,0"
                 FontFamily="Consolas"
                 MaxWidth="340"
                 Foreground="{DynamicResource AccentBrush}"
                 TextWrapping="Wrap" />
      <TextBlock x:Name="ErrorTextBlock"
                 Margin="0,10,0,0"
                 Foreground="#E57373"
                 Text="Enter a macro name."
                 Visibility="Collapsed" />
      </StackPanel>
    </Border>

    <StackPanel Grid.Row="3"
                Margin="0,14,0,0">
      <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                 Text="Saving again with the same name will overwrite the existing macro."
                 TextWrapping="Wrap" />
    </StackPanel>

    <StackPanel Grid.Row="4"
                Margin="0,16,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
      <Button Width="84"
              Margin="0,0,8,0"
              Click="CancelButton_OnClick"
              Content="Cancel"
              IsCancel="True" />
      <Button Width="84"
              Click="SaveButton_OnClick"
              Content="Save"
              IsDefault="True" />
    </StackPanel>
      </Grid>
    </ScrollViewer>
  </Border>
</Window>

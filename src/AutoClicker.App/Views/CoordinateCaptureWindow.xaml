<Window x:Class="AutoClicker.App.Views.CoordinateCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#01000000"
        ShowInTaskbar="False"
        Topmost="True">
  <Grid>
    <Border HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="24"
            Padding="12"
            Background="#CC101820"
            CornerRadius="8">
      <StackPanel>
        <TextBlock x:Name="CaptureInstructionTextBlock" Foreground="White" FontSize="16" FontWeight="SemiBold" Text="" />
        <TextBlock x:Name="CoordinateTextBlock" Margin="0,8,0,0" Foreground="White" Text="{Binding CoordinateText}" />
        <TextBlock x:Name="CaptureCancelHintTextBlock" Margin="0,4,0,0" Foreground="#FFD4D8DD" Text="" />
      </StackPanel>
    </Border>
  </Grid>
</Window>

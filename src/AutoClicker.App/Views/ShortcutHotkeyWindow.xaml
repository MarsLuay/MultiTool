<Window x:Class="AutoClicker.App.Views.ShortcutHotkeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitleText}"
        Width="1120"
        Height="720"
        MinWidth="820"
        MinHeight="420"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <Style TargetType="DataGrid">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceAltBrush}" />
      <Setter Property="AlternationCount" Value="2" />
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}" />
    </Style>
    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="8,6" />
    </Style>
    <Style TargetType="DataGridCell">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="6,4" />
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
          <Setter Property="Foreground" Value="{DynamicResource SelectionTextBrush}" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="DataGridRow">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding HasConflict}" Value="True">
          <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </DataTrigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
          <Setter Property="Foreground" Value="{DynamicResource SelectionTextBrush}" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Border Margin="12"
          Padding="16"
          Background="{DynamicResource SurfaceBrush}"
          BorderBrush="{DynamicResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="8">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock FontSize="22"
                 FontWeight="SemiBold"
                 Text="{Binding HeadingText}" />

      <StackPanel Grid.Row="1" Margin="0,10,0,0">
        <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" />
        <TextBlock Margin="0,6,0,0"
                   Foreground="{DynamicResource AccentBrush}"
                   Text="{Binding WarningText}"
                   TextWrapping="Wrap">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <Trigger Property="Text" Value="">
                  <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
        <TextBlock Margin="0,6,0,0"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Text="{Binding ReferenceNoteText}"
                   TextWrapping="Wrap">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <Trigger Property="Text" Value="">
                  <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
        <TextBlock Margin="0,6,0,0"
                   Foreground="{DynamicResource AccentBrush}"
                   FontWeight="SemiBold"
                   Text="{Binding ConflictWarningText}"
                   TextWrapping="Wrap">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <Trigger Property="Text" Value="">
                  <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </StackPanel>

      <Grid Grid.Row="2" Margin="0,12,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Margin="0,0,8,0"
                   VerticalAlignment="Center"
                   Text="{Binding SearchLabelText}" />
        <TextBox Grid.Column="1"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        <CheckBox Grid.Column="2"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center"
                  Content="{Binding ConflictsOnlyText}"
                  IsChecked="{Binding ShowOnlyConflicts}" />
      </Grid>

      <DataGrid Grid.Row="3"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserResizeRows="False"
                HeadersVisibility="Column"
                IsReadOnly="True"
                ItemsSource="{Binding ShortcutsView}"
                SelectionMode="Extended">
        <DataGrid.Columns>
          <DataGridTextColumn Header="{Binding DataContext.ColumnHotkeyText, RelativeSource={RelativeSource AncestorType=Window}}"
                              Binding="{Binding Hotkey}"
                              Width="140" />
          <DataGridTextColumn Header="{Binding DataContext.ColumnShortcutText, RelativeSource={RelativeSource AncestorType=Window}}"
                              Binding="{Binding ShortcutName}"
                              Width="170" />
          <DataGridTextColumn Header="{Binding DataContext.ColumnSourceText, RelativeSource={RelativeSource AncestorType=Window}}"
                              Binding="{Binding SourceLabel}"
                              Width="170" />
          <DataGridTextColumn Header="{Binding DataContext.ColumnAppliesToText, RelativeSource={RelativeSource AncestorType=Window}}"
                              Binding="{Binding AppliesTo}"
                              Width="190" />
          <DataGridTextColumn Header="{Binding DataContext.ColumnConflictText, RelativeSource={RelativeSource AncestorType=Window}}"
                              Binding="{Binding ConflictSummary}"
                              Width="220" />
          <DataGridTextColumn Header="{Binding DataContext.ColumnDetailsText, RelativeSource={RelativeSource AncestorType=Window}}"
                              Binding="{Binding Details}"
                              Width="2*" />
          <DataGridTextColumn Header="{Binding DataContext.ColumnFileText, RelativeSource={RelativeSource AncestorType=Window}}"
                              Binding="{Binding ShortcutPath}"
                              Width="2*" />
        </DataGrid.Columns>
      </DataGrid>

      <DockPanel Grid.Row="4" Margin="0,12,0,0">
        <TextBlock DockPanel.Dock="Left"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Text="{Binding FilterSummary}" />
        <Button Width="88"
                HorizontalAlignment="Right"
          Content="{Binding CloseButtonText}"
                Click="CloseButton_OnClick" />
      </DockPanel>
    </Grid>
  </Border>
</Window>

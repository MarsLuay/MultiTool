<Window x:Class="AutoClicker.App.Views.ShortcutHotkeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shortcut Key Explorer"
        Width="1120"
        Height="720"
        MinWidth="820"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="16">
    <Grid.Resources>
      <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Style.Triggers>
          <DataTrigger Binding="{Binding HasConflict}" Value="True">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
          </DataTrigger>
        </Style.Triggers>
      </Style>
    </Grid.Resources>

    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock FontSize="22"
               FontWeight="SemiBold"
               Text="Shortcut Key Explorer" />

    <StackPanel Grid.Row="1" Margin="0,10,0,0">
      <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" />
      <TextBlock Margin="0,6,0,0"
                 Foreground="{DynamicResource AccentBrush}"
                 Text="{Binding WarningText}"
                 TextWrapping="Wrap">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
              <Trigger Property="Text" Value="">
                <Setter Property="Visibility" Value="Collapsed" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>
      <TextBlock Margin="0,6,0,0"
                 Foreground="{DynamicResource MutedTextBrush}"
                 Text="{Binding ReferenceNoteText}"
                 TextWrapping="Wrap">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
              <Trigger Property="Text" Value="">
                <Setter Property="Visibility" Value="Collapsed" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>
      <TextBlock Margin="0,6,0,0"
                 Foreground="{DynamicResource AccentBrush}"
                 FontWeight="SemiBold"
                 Text="{Binding ConflictWarningText}"
                 TextWrapping="Wrap">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
              <Trigger Property="Text" Value="">
                <Setter Property="Visibility" Value="Collapsed" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>
    </StackPanel>

    <Grid Grid.Row="2" Margin="0,12,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0"
                 Margin="0,0,8,0"
                 VerticalAlignment="Center"
                 Text="Search" />
      <TextBox Grid.Column="1"
               Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
      <CheckBox Grid.Column="2"
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                Content="Show only conflicts"
                IsChecked="{Binding ShowOnlyConflicts}" />
    </Grid>

    <DataGrid Grid.Row="3"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              HeadersVisibility="Column"
              IsReadOnly="True"
              ItemsSource="{Binding ShortcutsView}"
              SelectionMode="Extended">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Hotkey"
                            Binding="{Binding Hotkey}"
                            Width="140" />
        <DataGridTextColumn Header="Shortcut"
                            Binding="{Binding ShortcutName}"
                            Width="170" />
        <DataGridTextColumn Header="Source"
                            Binding="{Binding SourceLabel}"
                            Width="170" />
        <DataGridTextColumn Header="Applies To"
                            Binding="{Binding AppliesTo}"
                            Width="190" />
        <DataGridTextColumn Header="Conflict"
                            Binding="{Binding ConflictSummary}"
                            Width="220" />
        <DataGridTextColumn Header="Details"
                            Binding="{Binding Details}"
                            Width="2*" />
        <DataGridTextColumn Header="Shortcut File"
                            Binding="{Binding ShortcutPath}"
                            Width="2*" />
      </DataGrid.Columns>
    </DataGrid>

    <DockPanel Grid.Row="4" Margin="0,12,0,0">
      <TextBlock DockPanel.Dock="Left"
                 VerticalAlignment="Center"
                 Foreground="{DynamicResource MutedTextBrush}"
                 Text="{Binding FilterSummary}" />
      <Button Width="88"
              HorizontalAlignment="Right"
              Content="Close"
              Click="CloseButton_OnClick" />
    </DockPanel>
  </Grid>
</Window>

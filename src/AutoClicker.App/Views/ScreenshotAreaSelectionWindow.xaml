<Window x:Class="AutoClicker.App.Views.ScreenshotAreaSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#22000000"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Cross">
  <Canvas x:Name="RootCanvas">
    <Border x:Name="SelectionBorder"
            Visibility="Collapsed"
            BorderBrush="#FFFFC857"
            BorderThickness="2"
            Background="#33FFC857" />
    <Border Canvas.Left="24"
            Canvas.Top="24"
            Padding="12"
            Background="#CC101820"
            CornerRadius="8">
      <StackPanel>
        <TextBlock x:Name="AreaInstructionTextBlock" Foreground="White" FontSize="16" FontWeight="SemiBold" Text="" />
        <TextBlock x:Name="AreaInstructionHintTextBlock" Margin="0,4,0,0" Foreground="#FFD4D8DD" Text="" />
      </StackPanel>
    </Border>
  </Canvas>
</Window>

<Window x:Class="AutoClicker.App.Views.ScreenshotOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="540"
        Height="500"
        MinWidth="460"
        MinHeight="430"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Topmost="True">
  <Border Margin="12"
          Padding="16"
          Background="{DynamicResource SurfaceBrush}"
          BorderBrush="{DynamicResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="8">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock FontSize="16"
                 FontWeight="SemiBold"
                Text="" />

      <TextBlock Grid.Row="1"
                 Margin="0,8,0,0"
                 Foreground="{DynamicResource MutedTextBrush}"
                  Text=""
                 TextWrapping="Wrap" />

      <ScrollViewer Grid.Row="2"
                    Margin="0,16,0,0"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <Button x:Name="FullScreenButton"
                  Margin="0,0,0,10"
                  Padding="14,12"
                  HorizontalContentAlignment="Left"
                  Click="FullScreenButton_OnClick">
            <StackPanel>
              <TextBlock FontWeight="SemiBold"
                          Text="" />
              <TextBlock Margin="0,4,0,0"
                         Foreground="{DynamicResource MutedTextBrush}"
                          Text=""
                         TextWrapping="Wrap" />
            </StackPanel>
          </Button>

          <Button x:Name="AreaButton"
                  Margin="0,0,0,10"
                  Padding="14,12"
                  HorizontalContentAlignment="Left"
                  Click="AreaButton_OnClick">
            <StackPanel>
              <TextBlock FontWeight="SemiBold"
                          Text="" />
              <TextBlock Margin="0,4,0,0"
                         Foreground="{DynamicResource MutedTextBrush}"
                          Text=""
                         TextWrapping="Wrap" />
            </StackPanel>
          </Button>

          <Border Padding="14,12"
                  Background="{DynamicResource SurfaceAltBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6">
            <StackPanel>
              <CheckBox x:Name="VideoRecordingCheckBox"
                        FontWeight="SemiBold"
                        Checked="VideoRecordingCheckBox_OnChecked"
                        Unchecked="VideoRecordingCheckBox_OnUnchecked"
                         Content="" />
              <TextBlock Margin="24,6,0,0"
                         Foreground="{DynamicResource MutedTextBrush}"
                          Text=""
                         TextWrapping="Wrap" />
              <TextBlock x:Name="VideoStatusTextBlock"
                         Margin="24,10,0,0"
                         Foreground="{DynamicResource MutedTextBrush}"
                          Text=""
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Button x:Name="CancelButton"
              Grid.Row="3"
              Margin="0,12,0,0"
              Width="84"
              HorizontalAlignment="Right"
              Click="CancelButton_OnClick"
               Content="" />
    </Grid>
  </Border>
</Window>

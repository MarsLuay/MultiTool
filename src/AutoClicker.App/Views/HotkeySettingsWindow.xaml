<Window x:Class="AutoClicker.App.Views.HotkeySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title=""
        Width="360"
        Height="200"
  Background="{DynamicResource WindowBackgroundBrush}"
  Foreground="{DynamicResource TextBrush}"
        PreviewMouseDown="HotkeySettingsWindow_OnPreviewMouseDown"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <Style x:Key="CaptureReadyButtonStyle" TargetType="ToggleButton">
      <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="CaptureBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    SnapsToDevicePixels="True">
              <ContentPresenter Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>

            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="CaptureBorder" Property="Background" Value="{DynamicResource InputActiveBackgroundBrush}" />
                <Setter TargetName="CaptureBorder" Property="BorderBrush" Value="{DynamicResource InputActiveBorderBrush}" />
                <Setter TargetName="CaptureBorder" Property="BorderThickness" Value="3" />
                <Setter Property="Foreground" Value="{DynamicResource InputActiveTextBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Border Background="{DynamicResource WindowBackgroundBrush}">
    <Grid x:Name="HotkeySettingsRootGrid"
          Margin="16"
          Focusable="True"
          FocusVisualStyle="{x:Null}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="170" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <TextBlock x:Name="ToggleHotkeyLabelTextBlock" Grid.Row="0" Grid.Column="0" Margin="0,0,8,12" VerticalAlignment="Center" Text="" />
    <ToggleButton x:Name="ToggleHotkeyTextBox"
                  Grid.Row="0"
                  Grid.Column="1"
                  Margin="0,0,0,12"
                  Style="{StaticResource CaptureReadyButtonStyle}"
                  GotKeyboardFocus="ToggleHotkeyTextBox_OnGotKeyboardFocus"
                  LostKeyboardFocus="ToggleHotkeyTextBox_OnLostKeyboardFocus"
                  PreviewMouseDown="ToggleHotkeyTextBox_OnPreviewMouseDown"
                  PreviewKeyDown="ToggleHotkeyTextBox_OnPreviewKeyDown"
                  Content="{Binding ToggleHotkeyDisplay}" />

    <TextBlock Grid.Row="1"
               x:Name="ToggleHotkeyWaitingTextBlock"
               Grid.Column="1"
               Margin="0,-8,0,12"
               Foreground="{DynamicResource AccentBrush}"
               Visibility="Collapsed"
               Text="">
      <TextBlock.Style>
        <Style TargetType="TextBlock">
          <Setter Property="Visibility" Value="Collapsed" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding ElementName=ToggleHotkeyTextBox, Path=IsChecked}" Value="True">
              <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </TextBlock.Style>
    </TextBlock>

    <TextBlock x:Name="PinWindowHotkeyLabelTextBlock" Grid.Row="2" Grid.Column="0" Margin="0,0,8,12" VerticalAlignment="Center" Text="" />
    <ToggleButton x:Name="PinWindowHotkeyTextBox"
            Grid.Row="2"
                  Grid.Column="1"
                  Margin="0,0,0,12"
                  Style="{StaticResource CaptureReadyButtonStyle}"
                  GotKeyboardFocus="PinWindowHotkeyTextBox_OnGotKeyboardFocus"
                  LostKeyboardFocus="ToggleHotkeyTextBox_OnLostKeyboardFocus"
                  PreviewMouseDown="PinWindowHotkeyTextBox_OnPreviewMouseDown"
                  PreviewKeyDown="PinWindowHotkeyTextBox_OnPreviewKeyDown"
                  Content="{Binding PinWindowHotkeyDisplay}" />

    <TextBlock Grid.Row="3"
               x:Name="PinWindowHotkeyWaitingTextBlock"
               Grid.Column="1"
               Margin="0,-8,0,12"
               Foreground="{DynamicResource AccentBrush}"
               Visibility="Collapsed"
               Text="">
      <TextBlock.Style>
        <Style TargetType="TextBlock">
          <Setter Property="Visibility" Value="Collapsed" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding ElementName=PinWindowHotkeyTextBox, Path=IsChecked}" Value="True">
              <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </TextBlock.Style>
    </TextBlock>

    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button x:Name="ResetButton" Margin="4" Padding="12,6" Content="" Command="{Binding ResetCommand}" />
      <Button x:Name="CancelButton" Margin="4" Padding="12,6" Content="" Click="CancelButton_OnClick" />
      <Button x:Name="SaveButton" Margin="4" Padding="12,6" Content="" Click="SaveButton_OnClick" />
    </StackPanel>
    </Grid>
  </Border>
</Window>

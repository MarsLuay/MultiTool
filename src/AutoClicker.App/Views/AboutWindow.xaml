<Window x:Class="AutoClicker.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="340"
        Height="180"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="20">
    <StackPanel VerticalAlignment="Center">
      <TextBlock x:Name="AppNameTextBlock" FontSize="22" FontWeight="Bold" Text="" />
      <TextBlock x:Name="AboutSubtitleTextBlock" Margin="0,8,0,0" Text="" TextWrapping="Wrap" />
      <TextBlock x:Name="VersionTextBlock" Margin="0,8,0,0" Text="" />
      <Button x:Name="CloseButton" Margin="0,16,0,0" Width="80" HorizontalAlignment="Right" Content="" Click="CloseButton_OnClick" />
    </StackPanel>
  </Grid>
</Window>

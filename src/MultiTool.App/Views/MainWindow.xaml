<Window x:Class="MultiTool.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:MultiTool.App.Views"
        Title="{Binding WindowTitle}"
        Width="520"
        Height="540"
        MinWidth="420"
        MinHeight="380"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        PreviewMouseDown="MainWindow_OnPreviewMouseDown"
        PreviewKeyDown="MainWindow_OnPreviewKeyDown"
        PreviewMouseWheel="MainWindow_OnPreviewMouseWheel"
        Topmost="{Binding IsTopMost}">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0"
                        CornerRadius="0"
                        GlassFrameThickness="0"
                        ResizeBorderThickness="6"
                        UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/MultiTool;component/Resources/MainWindowSharedResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border BorderBrush="{DynamicResource BorderBrush}"
          BorderThickness="1"
          Background="{DynamicResource WindowBackgroundBrush}">
      <Grid x:Name="MainRootGrid"
          Margin="0"
          Focusable="True"
          FocusVisualStyle="{x:Null}">
      <Grid.RowDefinitions>
        <RowDefinition Height="34" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0"
            Background="{DynamicResource SurfaceAltBrush}"
            MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown"
            MouseMove="TitleBar_OnMouseMove"
            MouseLeftButtonUp="TitleBar_OnMouseLeftButtonUp"
            LostMouseCapture="TitleBar_OnLostMouseCapture">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Margin="12,0,0,0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Image Width="14"
                 Height="14"
                 Margin="0,0,6,0"
                 Source="Resources/Icons/icon.ico">
            <Image.Style>
              <Style TargetType="Image">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsWindowPinned}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Image.Style>
          </Image>

          <TextBlock FontWeight="SemiBold"
                     Text="{Binding WindowTitle}" />

          <TextBlock Margin="8,0,0,0"
                     Foreground="{DynamicResource AccentBrush}"
                     FontWeight="SemiBold"
                     Text="[PINNED]">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsWindowPinned}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>

        <Button Grid.Column="1"
                Width="38"
                Height="26"
                Margin="0,4,0,4"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                Click="MinimizeButton_OnClick"
                Content="_" />
        <Button Grid.Column="2"
                Width="38"
                Height="26"
                Margin="0,4,0,4"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                Click="MaximizeRestoreButton_OnClick"
                Content="[ ]" />
        <Button Grid.Column="3"
                Width="38"
                Height="26"
                Margin="0,4,6,4"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                Click="CloseButton_OnClick"
                Content="X" />
      </Grid>

      <Border Grid.Row="1"
              Margin="16,12,16,0"
              Padding="10,8"
              Background="{DynamicResource SurfaceAltBrush}"
              BorderBrush="{DynamicResource AccentBrush}"
              BorderThickness="1"
              CornerRadius="6">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ShouldShowAdminModeBanner}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Column="0"
                     Text="{Binding AdminModeBannerText}"
                     TextWrapping="Wrap"
                     VerticalAlignment="Center" />

          <Button Grid.Column="1"
                  Margin="8,0,0,0"
                  Padding="4,2"
                  VerticalAlignment="Top"
                  Background="Transparent"
                  BorderThickness="0"
                  Command="{Binding DismissAdminBannerCommand}"
                  Content="X"
                  FontWeight="Bold"
                  Cursor="Hand" />
        </Grid>
      </Border>

      <Grid Grid.Row="2"
            Margin="16,12,16,16">
        <TabControl x:Name="MainTabControl"
                    SelectedIndex="{Binding SelectedMainTabIndex, Mode=TwoWay}"
                    SelectionChanged="MainTabControl_OnSelectionChanged">
          <TabControl.LayoutTransform>
            <ScaleTransform x:Name="MainContentScaleTransform"
                            ScaleX="1"
                            ScaleY="1" />
          </TabControl.LayoutTransform>
          <TabItem Header="{Binding ClickerTabHeaderText}">
            <views:ClickerTabView x:Name="ClickerTabContent"
                                  DataContext="{Binding ClickerTab}" />
          </TabItem>
          <TabItem Header="{Binding ScreenshotTabHeaderText}">
            <views:ScreenshotTabView x:Name="ScreenshotTabContent"
                                     DataContext="{Binding ScreenshotTab}" />
          </TabItem>
          <TabItem Header="{Binding MacroTabHeaderText}">
            <views:MacroTabView x:Name="MacroTabContent"
                                DataContext="{Binding MacroTab}" />
          </TabItem>
          <TabItem Header="{Binding InstallerTabHeaderText}">
            <views:InstallerTabView x:Name="InstallerTabContent"
                                    DataContext="{Binding InstallerTab}" />
          </TabItem>
          <TabItem Header="{Binding ToolsTabHeaderText}">
            <views:ToolsTabView x:Name="ToolsTabContent"
                                DataContext="{Binding ToolsTab}" />
          </TabItem>
          <TabItem x:Name="SettingsTabItem"
                   Header="{Binding SettingsTabHeaderText}">
            <views:SettingsTabView x:Name="SettingsTabContent"
                                   DataContext="{Binding SettingsTab}" />
          </TabItem>
        </TabControl>

      <Canvas x:Name="SillyConfettiCanvas"
              Grid.RowSpan="3"
              Panel.ZIndex="1000"
              IsHitTestVisible="False"
              Visibility="Collapsed"
              ClipToBounds="True" />
      </Grid>
    </Grid>
  </Border>
</Window>


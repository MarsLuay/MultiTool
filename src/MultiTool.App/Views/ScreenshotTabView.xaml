<UserControl x:Class="MultiTool.App.Views.ScreenshotTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/MultiTool;component/Resources/MainWindowSharedResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>
<ScrollViewer DataContext="{Binding Shell}" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="0,12,0,0">
          <GroupBox Header="Capture" Margin="0,0,0,12">
            <Grid Margin="12">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Margin="4" VerticalAlignment="Center" Text="{Binding ScreenshotHotkeyLabelText}" />
              <ToggleButton x:Name="ScreenshotHotkeyTextBox"
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="4"
                            Style="{StaticResource CaptureReadyButtonStyle}"
                            GotKeyboardFocus="ScreenshotHotkeyTextBox_OnGotKeyboardFocus"
                            LostKeyboardFocus="CaptureButton_OnLostKeyboardFocus"
                            PreviewMouseDown="ScreenshotHotkeyTextBox_OnPreviewMouseDown"
                            PreviewKeyDown="ScreenshotHotkeyTextBox_OnPreviewKeyDown"
                            Content="{Binding ScreenshotHotkeyDisplay}"
                            ToolTip="{Binding HotkeyEditToolTip}" />

              <TextBlock Grid.Row="1"
                         Grid.Column="1"
                         Margin="4,-2,4,8"
                         Foreground="{DynamicResource AccentBrush}"
                         Visibility="Collapsed"
                         Text="{Binding WaitingForKeyText}">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding ElementName=ScreenshotHotkeyTextBox, Path=IsChecked}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>

              <TextBlock Grid.Row="2" Grid.Column="0" Margin="4" VerticalAlignment="Center" Text="{Binding FolderLabelText}" />
              <TextBox Grid.Row="2"
                       Grid.Column="1"
                       Margin="4"
                       Text="{Binding ScreenshotFolderPath, UpdateSourceTrigger=PropertyChanged}" />
                      <Button Grid.Row="2"
                      Grid.Column="2"
                      Margin="4"
                      Padding="10,4"
                      Command="{Binding BrowseScreenshotFolderCommand}"
                      Content="{Binding BrowseButtonText}" />

              <TextBlock Grid.Row="3" Grid.Column="0" Margin="4" VerticalAlignment="Center" Text="{Binding PrefixLabelText}" />
              <TextBox Grid.Row="3"
                       Grid.Column="1"
                       Margin="4"
                       Text="{Binding ScreenshotFilePrefix, UpdateSourceTrigger=PropertyChanged}" />

              <TextBlock Grid.Row="4"
                         Grid.ColumnSpan="3"
                         Margin="4,4,4,0"
                         Foreground="{DynamicResource MutedTextBrush}"
                         Text="{Binding ScreenshotHelperText}"
                         TextWrapping="Wrap" />

                <WrapPanel Grid.Row="5" Grid.ColumnSpan="3" Margin="0,12,0,0" HorizontalAlignment="Right">
                <Button Margin="4" Padding="12,6" Command="{Binding CaptureScreenshotCommand}" Content="{Binding CaptureScreenButtonText}" />
                <Button Margin="4" Padding="12,6" Command="{Binding OpenScreenshotFolderCommand}" Content="{Binding OpenFolderButtonText}" />
              </WrapPanel>
            </Grid>
          </GroupBox>

          <GroupBox Header="Latest Screenshot">
            <Grid Margin="12">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <Border Grid.Row="0"
                       Margin="0,0,0,12"
                       MinHeight="240"
                       Padding="8"
                       Background="{DynamicResource SurfaceAltBrush}"
                       BorderBrush="{DynamicResource BorderBrush}"
                       BorderThickness="1"
                      CornerRadius="6">
                <Grid>
                  <MediaElement x:Name="LatestVideoPlayer"
                                Stretch="Uniform"
                                Source="{Binding LatestVideoSource}"
                                LoadedBehavior="Manual"
                                UnloadedBehavior="Stop"
                                MediaOpened="LatestVideoPlayer_OnMediaOpened"
                                MediaEnded="LatestVideoPlayer_OnMediaEnded">
                    <MediaElement.Style>
                      <Style TargetType="MediaElement">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsLatestMediaVideo}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </MediaElement.Style>
                  </MediaElement>

                  <Image Stretch="Uniform"
                         Source="{Binding LatestScreenshotPreview}">
                    <Image.Style>
                      <Style TargetType="Image">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding HasLatestScreenshot}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding IsLatestMediaVideo}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Image.Style>
                  </Image>

                  <TextBlock HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource MutedTextBrush}"
                             MaxWidth="260"
                             Text="{Binding LatestScreenshotPlaceholderText}"
                             TextAlignment="Center"
                             TextWrapping="Wrap">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding HasLatestScreenshot}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                          </DataTrigger>
                          <DataTrigger Binding="{Binding HasLatestVideo}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </Grid>
              </Border>

              <TextBlock Grid.Row="1"
                         Margin="0,0,0,6"
                         FontWeight="SemiBold"
                         Text="{Binding LatestScreenshotCaption}">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsLatestMediaVideo}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>

              <TextBlock Grid.Row="1"
                         Margin="0,0,0,6"
                         FontWeight="SemiBold"
                         Text="{Binding LatestVideoCaption, StringFormat=Video: {0}}">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsLatestMediaVideo}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>

              <TextBlock Grid.Row="2"
                         Margin="0,0,0,6"
                         Foreground="{DynamicResource MutedTextBrush}"
                         TextWrapping="Wrap">
                <Run Text="Latest video: " />
                <Run Text="{Binding LatestVideoCaption, Mode=OneWay}" />
              </TextBlock>

              <TextBlock Grid.Row="3"
                         Foreground="{DynamicResource MutedTextBrush}"
                         Text="{Binding ScreenshotStatusMessage}"
                         TextWrapping="Wrap" />
            </Grid>
          </GroupBox>
          </StackPanel>
        </ScrollViewer>
</UserControl>

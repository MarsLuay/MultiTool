<UserControl x:Class="MultiTool.App.Views.ToolsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/MultiTool;component/Resources/MainWindowSharedResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>
<ScrollViewer DataContext="{Binding Shell}" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="0,12,0,0">
            <GroupBox Header="{Binding NicheToolsHeaderText}" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Focused utility tools for cleanup and one-off maintenance jobs that do not fit neatly into the main tabs."
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <Expander Header="Input and Display"
                      IsExpanded="False"
                      Margin="0,0,0,12"
                      Style="{StaticResource InstallerInlineExpanderStyle}">
              <StackPanel>

            <GroupBox Header="{Binding ShortcutKeyExplorerHeaderText}" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Deep-scan fixed drives for Windows .lnk shortcut files with assigned hotkeys, heuristically discover compatible app keymap files, then combine those with built-in Windows and common shortcuts like Ctrl + C, Alt + Tab, and Win + R in one viewer."
                           TextWrapping="Wrap" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ShowAssignedShortcutHotkeysCommand}"
                      Content="{Binding ShortcutExplorerButtonText}" />
                </WrapPanel>

                <Border Margin="0,12,0,0"
                        Padding="10"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsShortcutHotkeyScanProgressVisible}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>

                  <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding ShortcutHotkeyScanProgressSummary}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding ShortcutHotkeyScanProgressPath}">
                      <Run Text="Current folder: " />
                      <Run Text="{Binding ShortcutHotkeyScanProgressPath, Mode=OneWay}" />
                    </TextBlock>
                    <ProgressBar Margin="0,8,0,0"
                                 Height="14"
                                 Minimum="0"
                                 Maximum="{Binding ShortcutHotkeyScanProgressMaximum}"
                                 Value="{Binding ShortcutHotkeyScanProgressValue}" />
                  </StackPanel>
                </Border>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding ShortcutHotkeyStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Display Refresh" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Check if your monitors are running at their fastest refresh rate. A higher refresh rate makes everything on screen feel smoother."
                           TextWrapping="Wrap" />

                <TextBlock Margin="0,8,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding DisplayRefreshSummary}" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ScanDisplayRefreshRecommendationsCommand}"
                          Content="Check Displays" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ApplyDisplayRefreshRecommendationsCommand}"
                          Content="Apply Best Rate" />
                </WrapPanel>

                <Border Margin="0,12,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <ListBox MaxHeight="220"
                           ItemContainerStyle="{StaticResource VirtualizedCardListItemStyle}"
                           ItemsSource="{Binding DisplayRefreshRecommendations}"
                           Style="{StaticResource VirtualizedCardListStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10"
                                  Padding="10"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6">
                            <StackPanel>
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding DisplayName}" />

                              <TextBlock Margin="0,6,0,0"
                                         Text="{Binding FrequencySummaryText}"
                                         TextWrapping="Wrap" />

                              <TextBlock Margin="0,6,0,0"
                                         Text="{Binding StatusText}"
                                         TextWrapping="Wrap">
                                <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding NeedsChange}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </TextBlock.Style>
                              </TextBlock>

                              <TextBlock Margin="0,6,0,0"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         Text="{Binding DeviceName}"
                                         TextWrapping="Wrap" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding DisplayRefreshStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Mouse Speed (DPI Helper)" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Make the mouse pointer feel slower or faster for this Windows account. This changes Windows pointer speed, which is the closest built-in option to a generic DPI change when your mouse does not have its own software."
                           TextWrapping="Wrap" />

                <TextBlock Margin="0,8,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding MouseSensitivitySummary}" />

                <TextBlock Margin="0,6,0,0"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="{Binding MouseSensitivitySelectionGuidance}"
                           TextWrapping="Wrap" />

                <Grid Margin="0,12,0,0">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Grid.Column="0"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"
                             Text="Pointer Feel" />
                  <Slider Grid.Column="1"
                          Minimum="1"
                          Maximum="20"
                          SmallChange="1"
                          LargeChange="1"
                          TickFrequency="1"
                          IsSnapToTickEnabled="True"
                          AutoToolTipPlacement="TopLeft"
                          AutoToolTipPrecision="0"
                          Value="{Binding SelectedMouseSensitivityLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                  <TextBlock Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,8,0,0"
                             FontWeight="SemiBold"
                             Text="{Binding MouseSensitivitySelectedLevelLabel}" />

                  <UniformGrid Grid.Row="2"
                               Grid.Column="1"
                               Margin="0,8,0,0"
                               Columns="5">
                    <TextBlock HorizontalAlignment="Left"
                               FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding MouseSensitivityVerySlowLabelText}" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding MouseSensitivitySlowLabelText}" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding MouseSensitivityBalancedLabelText}" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding MouseSensitivityFastLabelText}" />
                    <TextBlock HorizontalAlignment="Right"
                               FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding MouseSensitivityVeryFastLabelText}" />
                  </UniformGrid>
                </Grid>

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding RefreshMouseSensitivityStatusCommand}"
                          Content="Check Current Speed" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ApplyMouseSensitivityCommand}"
                          Content="Use This Speed" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding OpenMouseSettingsCommand}"
                          Content="Open Windows Mouse Settings" />
                </WrapPanel>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding MouseSensitivityStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

              </StackPanel>
            </Expander>

            <Expander Header="Hardware and Drivers"
                      IsExpanded="False"
                      Margin="0,0,0,12"
                      Style="{StaticResource InstallerInlineExpanderStyle}">
              <StackPanel>

            <GroupBox Header="Drive Health (SMART)" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Pick a physical drive, run an on-demand SMART scan, then export the attribute table when you want the raw details. MultiTool keeps the results cached for a while after scanning, but it does not poll drive health in the background."
                           TextWrapping="Wrap" />

                <Grid Margin="0,12,0,0">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Grid.Column="0"
                             Margin="0,0,10,0"
                             VerticalAlignment="Center"
                             Text="Drive" />

                  <ComboBox Grid.Column="1"
                            MinWidth="420"
                            Margin="0,0,0,8"
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{Binding DriveSmartTargets}"
                            SelectedItem="{Binding SelectedDriveSmartTarget, Mode=TwoWay}" />

                  <WrapPanel Grid.Row="1"
                             Grid.Column="1"
                             HorizontalAlignment="Right">
                    <Button Margin="4"
                            Padding="12,6"
                            Command="{Binding LoadDriveSmartTargetsCommand}"
                            Content="Load Drives" />
                    <Button Margin="4"
                            Padding="12,6"
                            Command="{Binding ScanSelectedDriveSmartCommand}"
                            Content="Scan Selected Drive" />
                    <Button Margin="4"
                            Padding="12,6"
                            Command="{Binding ExportDriveSmartReportCommand}"
                            Content="Export SMART Data" />
                  </WrapPanel>
                </Grid>

                <Border Margin="0,12,0,0"
                        Padding="10"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding DriveSmartSelectedDriveSummary}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource AccentBrush}"
                               TextWrapping="Wrap">
                      <Run Text="Overall health: " />
                      <Run Text="{Binding DriveSmartOverallHealth, Mode=OneWay}" />
                    </TextBlock>

                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding DriveSmartReportSummary}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding DriveSmartLastScannedSummary}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <Grid>
                    <ListView MaxHeight="280"
                              ItemsSource="{Binding DriveSmartAttributes}"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                      <ListView.Style>
                        <Style TargetType="ListView">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding HasDriveSmartAttributes}" Value="True">
                              <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </ListView.Style>
                      <ListView.View>
                        <GridView AllowsColumnReorder="False">
                          <GridViewColumn Width="70" Header="Byte">
                            <GridViewColumn.CellTemplate>
                              <DataTemplate>
                                <TextBlock FontFamily="Consolas"
                                           Text="{Binding Byte}" />
                              </DataTemplate>
                            </GridViewColumn.CellTemplate>
                          </GridViewColumn>
                          <GridViewColumn Width="90" Header="Status" DisplayMemberBinding="{Binding Status}" />
                          <GridViewColumn Width="260" Header="Description" DisplayMemberBinding="{Binding Description}" />
                          <GridViewColumn Width="220" Header="Raw Data">
                            <GridViewColumn.CellTemplate>
                              <DataTemplate>
                                <TextBlock FontFamily="Consolas"
                                           Text="{Binding RawData}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding RawData}" />
                              </DataTemplate>
                            </GridViewColumn.CellTemplate>
                          </GridViewColumn>
                        </GridView>
                      </ListView.View>
                    </ListView>

                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="SMART attributes will appear here after you scan the selected drive."
                               TextAlignment="Center"
                               TextWrapping="Wrap">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility" Value="Visible" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding HasDriveSmartAttributes}" Value="True">
                              <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Grid>
                </Border>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding DriveSmartStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="SSD Benchmark" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Choose a mounted SSD volume, run the four WinSAT benchmark modes on demand, then export the results when you want a record. MultiTool keeps the last result cached for a while after you run it, but it does not benchmark anything in the background."
                           TextWrapping="Wrap" />

                <Grid Margin="0,12,0,0">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Grid.Column="0"
                             Margin="0,0,10,0"
                             VerticalAlignment="Center"
                             Text="SSD" />

                  <ComboBox Grid.Column="1"
                            MinWidth="420"
                            Margin="0,0,0,8"
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{Binding StorageBenchmarkTargets}"
                            SelectedItem="{Binding SelectedStorageBenchmarkTarget, Mode=TwoWay}" />

                  <WrapPanel Grid.Row="1"
                             Grid.Column="1"
                             HorizontalAlignment="Right">
                    <Button Margin="4"
                            Padding="12,6"
                            Command="{Binding LoadStorageBenchmarkTargetsCommand}"
                            Content="Load SSDs" />
                    <Button Margin="4"
                            Padding="12,6"
                            Command="{Binding RunSelectedStorageBenchmarkCommand}"
                            Content="Start Benchmark" />
                    <Button Margin="4"
                            Padding="12,6"
                            Command="{Binding ExportStorageBenchmarkReportCommand}"
                            Content="Export Results" />
                  </WrapPanel>
                </Grid>

                <Border Margin="0,12,0,0"
                        Padding="10"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding StorageBenchmarkSelectedDriveSummary}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource AccentBrush}"
                               Text="{Binding StorageBenchmarkBalanceAssessment}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding StorageBenchmarkSummary}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding StorageBenchmarkDetectedSystemSummary}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding StorageBenchmarkLastBenchmarkedSummary}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="10"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStorageBenchmarkProgressVisible}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <StackPanel>
                    <ProgressBar Height="10"
                                 Minimum="0"
                                 Maximum="{Binding StorageBenchmarkProgressMaximum}"
                                 Value="{Binding StorageBenchmarkProgressValue}" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding StorageBenchmarkProgressSummary}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <Grid>
                    <ListView MaxHeight="240"
                              ItemsSource="{Binding StorageBenchmarkResults}"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                      <ListView.Style>
                        <Style TargetType="ListView">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding HasStorageBenchmarkResults}" Value="True">
                              <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </ListView.Style>
                      <ListView.View>
                        <GridView AllowsColumnReorder="False">
                          <GridViewColumn Width="130" Header="Mode" DisplayMemberBinding="{Binding Mode}" />
                          <GridViewColumn Width="120" Header="Speed">
                            <GridViewColumn.CellTemplate>
                              <DataTemplate>
                                <TextBlock FontFamily="Consolas"
                                           Text="{Binding ThroughputMegabytesPerSecond, StringFormat={}{0:N2} MB/s}" />
                              </DataTemplate>
                            </GridViewColumn.CellTemplate>
                          </GridViewColumn>
                          <GridViewColumn Width="110" Header="IOPS">
                            <GridViewColumn.CellTemplate>
                              <DataTemplate>
                                <TextBlock FontFamily="Consolas"
                                           Text="{Binding Iops, StringFormat={}{0:N0}}" />
                              </DataTemplate>
                            </GridViewColumn.CellTemplate>
                          </GridViewColumn>
                          <GridViewColumn Width="90" Header="Block Size">
                            <GridViewColumn.CellTemplate>
                              <DataTemplate>
                                <TextBlock FontFamily="Consolas"
                                           Text="{Binding BlockSizeBytes, StringFormat={}{0:N0} B}" />
                              </DataTemplate>
                            </GridViewColumn.CellTemplate>
                          </GridViewColumn>
                          <GridViewColumn Width="320" Header="Notes" DisplayMemberBinding="{Binding Notes}" />
                        </GridView>
                      </ListView.View>
                    </ListView>

                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="SSD benchmark results will appear here after you run the selected drive."
                               TextAlignment="Center"
                               TextWrapping="Wrap">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility" Value="Visible" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding HasStorageBenchmarkResults}" Value="True">
                              <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Grid>
                </Border>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding StorageBenchmarkStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Hardware Check" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Scan the PC for core hardware details like the system model, Windows version, CPU, memory, motherboard, BIOS, graphics adapters, storage health, partitions, live sensor telemetry, PCIe devices, and RAID or Storage Spaces details."
                           TextWrapping="Wrap" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ScanHardwareCheckCommand}"
                          Content="Scan Hardware" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding CopyHardwareCheckInfoCommand}"
                          Content="Copy Info" />
                </WrapPanel>

                <Border Margin="0,12,0,0"
                        Padding="10"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding HardwareCheckSystemSummary}" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding HardwareCheckHealthSummary}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding HardwareCheckOperatingSystemSummary}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding HardwareCheckProcessorSummary}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding HardwareCheckMemorySummary}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding HardwareCheckMotherboardSummary}"
                               TextWrapping="Wrap" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding HardwareCheckBiosSummary}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <TextBlock Margin="0,12,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding HardwareGraphicsSummary}" />

                <Border Margin="0,8,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <ListBox MaxHeight="160"
                           ItemContainerStyle="{StaticResource VirtualizedCardListItemStyle}"
                           ItemsSource="{Binding HardwareGraphicsAdapters}"
                           Style="{StaticResource VirtualizedCardListStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10"
                                  Padding="10"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6">
                            <StackPanel>
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding Name}" />

                              <TextBlock Margin="0,6,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="Driver: " />
                                <Run Text="{Binding DriverVersion, Mode=OneWay}" />
                                <Run Text="  |  Memory: " />
                                <Run Text="{Binding AdapterMemory, Mode=OneWay}" />
                              </TextBlock>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <TextBlock Margin="0,12,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding HardwareSensorSummary}" />

                <Border Margin="0,8,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasHardwareSensors}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>

                  <ListBox MaxHeight="180"
                           ItemContainerStyle="{StaticResource VirtualizedCardListItemStyle}"
                           ItemsSource="{Binding HardwareSensors}"
                           Style="{StaticResource VirtualizedCardListStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10"
                                  Padding="10"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6">
                            <StackPanel>
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding Name}" />

                              <TextBlock Margin="0,6,0,0"
                                         TextWrapping="Wrap">
                                <Run Text="Category: " />
                                <Run Text="{Binding Category, Mode=OneWay}" />
                                <Run Text="  |  Reading: " />
                                <Run Text="{Binding CurrentValue, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="Source: " />
                                <Run Text="{Binding Source, Mode=OneWay}" />
                                <Run Text="  |  Status: " />
                                <Run Text="{Binding Status, Mode=OneWay}" />
                              </TextBlock>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <TextBlock Margin="0,12,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding HardwarePciSummary}" />

                <Border Margin="0,8,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasHardwarePciDevices}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>

                  <ListBox MaxHeight="220"
                           ItemContainerStyle="{StaticResource VirtualizedCardListItemStyle}"
                           ItemsSource="{Binding HardwarePciDevices}"
                           Style="{StaticResource VirtualizedCardListStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10"
                                  Padding="10"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6">
                            <StackPanel>
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding Name}" />

                              <TextBlock Margin="0,6,0,0"
                                         TextWrapping="Wrap">
                                <Run Text="Class: " />
                                <Run Text="{Binding DeviceClass, Mode=OneWay}" />
                                <Run Text="  |  Manufacturer: " />
                                <Run Text="{Binding Manufacturer, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="Location: " />
                                <Run Text="{Binding Location, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="Status: " />
                                <Run Text="{Binding Status, Mode=OneWay}" />
                              </TextBlock>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <TextBlock Margin="0,12,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding HardwareStorageSummary}" />

                <Border Margin="0,8,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <ListBox MaxHeight="180"
                           ItemContainerStyle="{StaticResource VirtualizedCardListItemStyle}"
                           ItemsSource="{Binding HardwareStorageDrives}"
                           Style="{StaticResource VirtualizedCardListStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10"
                                  Padding="10"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6">
                            <StackPanel>
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding Model}" />

                              <TextBlock Margin="0,6,0,0"
                                         TextWrapping="Wrap">
                                <Run Text="Size: " />
                                <Run Text="{Binding Size, Mode=OneWay}" />
                                <Run Text="  |  Interface: " />
                                <Run Text="{Binding InterfaceType, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="Media: " />
                                <Run Text="{Binding MediaType, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         TextWrapping="Wrap">
                                <Run Text="Health: " />
                                <Run Text="{Binding HealthStatus, Mode=OneWay}" />
                                <Run Text="  |  SMART: " />
                                <Run Text="{Binding SmartStatus, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="Firmware: " />
                                <Run Text="{Binding FirmwareVersion, Mode=OneWay}" />
                                <Run Text="  |  Serial: " />
                                <Run Text="{Binding SerialNumber, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         Text="{Binding Notes}"
                                         TextWrapping="Wrap">
                                <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                      <Trigger Property="Text" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                      </Trigger>
                                    </Style.Triggers>
                                  </Style>
                                </TextBlock.Style>
                              </TextBlock>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <TextBlock Margin="0,12,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding HardwarePartitionSummary}" />

                <Border Margin="0,8,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasHardwareStoragePartitions}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>

                  <ListBox MaxHeight="220"
                           ItemContainerStyle="{StaticResource VirtualizedCardListItemStyle}"
                           ItemsSource="{Binding HardwareStoragePartitions}"
                           Style="{StaticResource VirtualizedCardListStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10"
                                  Padding="10"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6">
                            <StackPanel>
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding PartitionName}" />

                              <TextBlock Margin="0,6,0,0"
                                         TextWrapping="Wrap">
                                <Run Text="Disk: " />
                                <Run Text="{Binding DiskName, Mode=OneWay}" />
                                <Run Text="  |  Size: " />
                                <Run Text="{Binding Size, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         TextWrapping="Wrap">
                                <Run Text="Type: " />
                                <Run Text="{Binding Type, Mode=OneWay}" />
                                <Run Text="  |  Volume: " />
                                <Run Text="{Binding Volume, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="File System: " />
                                <Run Text="{Binding FileSystem, Mode=OneWay}" />
                                <Run Text="  |  Free Space: " />
                                <Run Text="{Binding FreeSpace, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="Status: " />
                                <Run Text="{Binding Status, Mode=OneWay}" />
                              </TextBlock>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <TextBlock Margin="0,12,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding HardwareRaidSummary}" />

                <Border Margin="0,8,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasHardwareRaidDetails}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>

                  <ListBox MaxHeight="180"
                           ItemContainerStyle="{StaticResource VirtualizedCardListItemStyle}"
                           ItemsSource="{Binding HardwareRaidDetails}"
                           Style="{StaticResource VirtualizedCardListStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10"
                                  Padding="10"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6">
                            <StackPanel>
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding Name}" />

                              <TextBlock Margin="0,6,0,0"
                                         TextWrapping="Wrap">
                                <Run Text="Type: " />
                                <Run Text="{Binding Type, Mode=OneWay}" />
                                <Run Text="  |  Status: " />
                                <Run Text="{Binding Status, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         TextWrapping="Wrap">
                                <Run Text="Details: " />
                                <Run Text="{Binding Details, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="Source: " />
                                <Run Text="{Binding Source, Mode=OneWay}" />
                              </TextBlock>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding HardwareCheckStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Driver Updates" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Detect this PC's hardware, scan Windows Update for matching driver updates, preselect recommended items, show optional ones separately, and install only the drivers you confirm. Some driver offers can only be finished through Windows Update's own Optional Updates flow."
                           TextWrapping="Wrap" />

                <TextBlock Margin="0,8,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding DriverHardwareSummary}" />

                <TextBlock Margin="0,4,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding DriverUpdateSelectionSummary}" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ScanDriverUpdatesCommand}"
                          Content="Scan Drivers" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding OpenWindowsUpdateOptionalUpdatesCommand}"
                          Content="Open Optional Updates" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding SelectRecommendedDriverUpdatesCommand}"
                          Content="Select Recommended" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding SelectAllDriverUpdatesCommand}"
                          Content="Select All" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ClearDriverUpdateSelectionCommand}"
                          Content="Clear" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding InstallSelectedDriverUpdatesCommand}"
                          Content="Install Selected" />
                </WrapPanel>

                <TextBlock Margin="0,12,0,0"
                           FontWeight="SemiBold"
                           Text="Detected Hardware" />

                <Border Margin="0,8,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <ListBox MaxHeight="180"
                           ItemContainerStyle="{StaticResource VirtualizedCardListItemStyle}"
                           ItemsSource="{Binding DriverHardwareInventory}"
                           Style="{StaticResource VirtualizedCardListStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10"
                                  Padding="10"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6">
                            <StackPanel>
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding DeviceName}" />

                              <TextBlock Margin="0,6,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="Manufacturer: " />
                                <Run Text="{Binding Manufacturer, Mode=OneWay}" />
                                <Run Text="  |  Provider: " />
                                <Run Text="{Binding DriverProvider, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="Driver Version: " />
                                <Run Text="{Binding DriverVersion, Mode=OneWay}" />
                                <Run Text="  |  Class: " />
                                <Run Text="{Binding DeviceClass, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,6,0,0"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         Text="{Binding DeviceId}"
                                         TextWrapping="Wrap" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <TextBlock Margin="0,12,0,0"
                           FontWeight="SemiBold"
                           Text="Windows Update Driver Recommendations" />

                <Border Margin="0,8,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <ListBox MaxHeight="260"
                           ItemContainerStyle="{StaticResource VirtualizedCardListItemStyle}"
                           ItemsSource="{Binding DriverUpdateCandidates}"
                           Style="{StaticResource VirtualizedCardListStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10"
                                  Padding="10"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6">
                            <StackPanel>
                              <CheckBox IsChecked="{Binding IsSelected}">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding Title}" />
                              </CheckBox>

                              <TextBlock Margin="20,6,0,0"
                                         FontWeight="SemiBold"
                                         Text="{Binding ClassificationText}">
                                <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding IsOptional}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </TextBlock.Style>
                              </TextBlock>

                              <TextBlock Margin="20,4,0,0"
                                         Text="{Binding InstallFlowText}"
                                         TextWrapping="Wrap">
                                <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding RequiresUserInput}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </TextBlock.Style>
                              </TextBlock>

                              <TextBlock Margin="20,6,0,0"
                                         TextWrapping="Wrap">
                                <Run Text="Model: " />
                                <Run Text="{Binding DriverModel, Mode=OneWay}" />
                                <Run Text="  |  Manufacturer: " />
                                <Run Text="{Binding DriverManufacturer, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="20,4,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="Class: " />
                                <Run Text="{Binding DriverClass, Mode=OneWay}" />
                                <Run Text="  |  Driver Date: " />
                                <Run Text="{Binding DriverDate, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="20,6,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         Text="{Binding Description}"
                                         TextWrapping="Wrap" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding DriverUpdateStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

              </StackPanel>
            </Expander>

            <Expander Header="Windows Tweaks"
                      IsExpanded="False"
                      Margin="0,0,0,12"
                      Style="{StaticResource InstallerInlineExpanderStyle}">
              <StackPanel>

            <GroupBox Header="Dark Mode Helper" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Apply Windows dark mode preferences where the operating system and installed apps support them. This covers the Windows shell preference, supported apps, and MultiTool itself."
                           TextWrapping="Wrap" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ApplySystemDarkModeCommand}"
                          Content="Apply Dark Mode" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding OpenWindowsColorSettingsCommand}"
                          Content="Open Color Settings" />
                </WrapPanel>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding DarkModeToolStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Pin Window" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="{Binding PinWindowDescriptionText}"
                           TextWrapping="Wrap" />

                <Border Margin="0,12,0,0"
                        Padding="10"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <StackPanel>
                    <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding PinWindowHotkeyFieldLabelText}" />
                    <WrapPanel Margin="0,6,0,0">
                      <ToggleButton x:Name="PinWindowHotkeyTextBox"
                                    MinWidth="108"
                                    Style="{StaticResource CaptureReadyButtonStyle}"
                                    GotKeyboardFocus="PinWindowHotkeyTextBox_OnGotKeyboardFocus"
                                    LostKeyboardFocus="CaptureButton_OnLostKeyboardFocus"
                                    PreviewMouseDown="PinWindowHotkeyTextBox_OnPreviewMouseDown"
                                    PreviewKeyDown="PinWindowHotkeyTextBox_OnPreviewKeyDown"
                                    Content="{Binding PinWindowHotkeyLabel}"
                                    ToolTip="{Binding HotkeyEditToolTip}" />
                      <Button Margin="8,0,0,0"
                              Padding="12,6"
                              Command="{Binding ClearPinWindowHotkeyCommand}"
                              Content="{Binding HotkeyResetButtonText}" />
                    </WrapPanel>
                    <TextBlock Margin="4,4,4,0"
                               Foreground="{DynamicResource AccentBrush}"
                               Visibility="Collapsed"
                               Text="{Binding WaitingForKeyText}">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=PinWindowHotkeyTextBox, Path=IsChecked}" Value="True">
                              <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding PinWindowHotkeySummary}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Replace Windows Search" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Windows Search (Win + S) is slow for many users. This replaces it with Flow Launcher, a faster search bar that finds apps, files, and folders instantly. It also installs Everything for lightning-fast file search behind the scenes."
                           TextWrapping="Wrap" />

                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="An administrator prompt may appear when turning Windows Search on or off."
                           TextWrapping="Wrap" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding RefreshSearchReplacementStatusCommand}"
                          Content="Refresh Status" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ApplySearchReplacementCommand}"
                          Content="Replace Search" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding RestoreSearchReplacementCommand}"
                          Content="Restore Windows Search" />
                </WrapPanel>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding SearchReplacementStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Re-index Windows Search" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Force Windows Search to rebuild its index if files are missing from search results or indexing got stuck. This can take several minutes and may prompt for administrator permission."
                           TextWrapping="Wrap" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding RefreshSearchReindexStatusCommand}"
                          Content="Refresh Status" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ReindexWindowsSearchCommand}"
                          Content="Re-index Now" />
                </WrapPanel>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding SearchReindexStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Stop Telemetry" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Reduce Windows telemetry by setting machine-level data collection policy to minimum, disabling common telemetry services, and turning off high-noise telemetry scheduled tasks. An administrator prompt may appear."
                           TextWrapping="Wrap" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding RefreshTelemetryStatusCommand}"
                          Content="Refresh Status" />
                  <Button Margin="4"
                    Padding="12,6"
                    Command="{Binding RestoreTelemetryDefaultsCommand}"
                    Content="Restore Defaults" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ApplyTelemetryReductionCommand}"
                          Content="Stop Telemetry" />
                </WrapPanel>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding TelemetryToolStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Remove OneDrive" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Detect whether OneDrive is still present on this PC, apply the machine-level policy that disables OneDrive file sync, and run Windows' built-in OneDrive uninstaller when it is available. Applying the policy may trigger a Windows administrator prompt."
                           TextWrapping="Wrap" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding RefreshOneDriveStatusCommand}"
                          Content="Refresh Status" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding RemoveOneDriveCommand}"
                          Content="Remove OneDrive" />
                </WrapPanel>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding OneDriveToolStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Remove Edge" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Detect whether Microsoft Edge is installed and remove it using the developer-override method. This bypasses the normal block that prevents removing Edge on non-European Windows devices. An administrator prompt will appear during removal."
                           TextWrapping="Wrap" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding RefreshEdgeStatusCommand}"
                          Content="Refresh Status" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding RemoveEdgeCommand}"
                          Content="Remove Edge" />
                </WrapPanel>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding EdgeToolStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Swap Fn and Ctrl (Lenovo)" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="For Lenovo laptops where Fn and Ctrl are reversed, this checks Lenovo BIOS support and flips the key positions. An administrator prompt appears when applying the change."
                           TextWrapping="Wrap" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding RefreshFnCtrlSwapStatusCommand}"
                          Content="Refresh Status" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ToggleFnCtrlSwapCommand}"
                          Content="Toggle Fn/Ctrl" />
                </WrapPanel>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding FnCtrlSwapStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Windows 11 EEA Media Prep" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Microsoft does not publish a separate Europe-only Windows 11 image. This button downloads the official Windows 11 Media Creation Tool, builds an Ireland-based EEA answer file, opens the prep folder, and watches for the finished USB so MultiTool can copy the file onto it automatically."
                           TextWrapping="Wrap" />

                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="If you want English International media, choose it in the Microsoft tool when the language step appears."
                           TextWrapping="Wrap" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding PrepareWindows11EeaMediaCommand}"
                          Content="Prepare EEA Media" />
                </WrapPanel>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding Windows11EeaInstallStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

              </StackPanel>
            </Expander>

            <Expander Header="Utilities"
                      IsExpanded="False"
                      Margin="0,0,0,12"
                      Style="{StaticResource InstallerInlineExpanderStyle}">
              <StackPanel>

              <GroupBox Header="IPv4 App Activity" Margin="0,0,0,12">
                <StackPanel Margin="12">
                  <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                             Text="See which Windows apps are using IPv4 right now, including live connections and ports that are waiting for traffic."
                             TextWrapping="Wrap" />

                <TextBlock Margin="0,8,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding Ipv4SocketSummary}"
                           TextWrapping="Wrap" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                    <Button Margin="4"
                            Padding="12,6"
                           Command="{Binding CaptureIpv4SocketSnapshotCommand}"
                           Content="Refresh Activity" />
                    <Button Margin="4"
                            Padding="12,6"
                           Command="{Binding CopyIpv4SocketSnapshotCommand}"
                           Content="Copy Activity" />
                  </WrapPanel>

                  <TextBlock Margin="0,12,0,0"
                             Foreground="{DynamicResource MutedTextBrush}"
                            Text="Click Refresh Activity to load the current IPv4 app activity."
                             TextWrapping="Wrap">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasIpv4SocketEntries}" Value="True">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>

                <Border Margin="0,12,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasIpv4SocketEntries}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>

                  <ListBox MaxHeight="320"
                           ItemContainerStyle="{StaticResource VirtualizedCardListItemStyle}"
                           ItemsSource="{Binding Ipv4SocketEntries}"
                           Style="{StaticResource VirtualizedCardListStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10"
                                  Padding="10"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6">
                            <StackPanel>
                              <TextBlock FontWeight="SemiBold"
                                         Text="{Binding ProgramSummary}"
                                         TextWrapping="Wrap" />

                              <TextBlock Margin="0,4,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="{Binding EntryKindLabel, Mode=OneWay}" />
                                <Run Text="  |  " />
                                <Run Text="{Binding Protocol, Mode=OneWay}" />
                                <Run Text="  " />
                                <Run Text="{Binding State, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,6,0,0"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         TextWrapping="Wrap">
                                <Run Text="Local:  " />
                                <Run Text="{Binding LocalEndpoint, Mode=OneWay}" />
                              </TextBlock>

                              <TextBlock Margin="0,4,0,0"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         TextWrapping="Wrap">
                                <Run Text="Remote: " />
                                <Run Text="{Binding RemoteEndpoint, Mode=OneWay}" />
                              </TextBlock>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding Ipv4SocketStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Useful Sites" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Reveal a curated list of handy sites, then open the ones you want with one click."
                           TextWrapping="Wrap" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ToggleUsefulSitesCommand}"
                          Content="{Binding UsefulSitesToggleText}" />
                </WrapPanel>

                <Border Margin="0,12,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding AreUsefulSitesVisible}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>

                  <ItemsControl ItemsSource="{Binding UsefulSites}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,10"
                                Padding="10"
                                Background="{DynamicResource ControlBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                          <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="{Binding DisplayName}" />

                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="{Binding Description}"
                                       TextWrapping="Wrap" />

                            <Button Margin="0,8,0,0"
                                    Style="{StaticResource LinkButtonStyle}"
                                    Command="{Binding DataContext.OpenUsefulSiteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                              <TextBlock FontFamily="Consolas"
                                         FontSize="11"
                                         Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                         Text="{Binding Url}"
                                         TextDecorations="Underline"
                                         TextWrapping="Wrap" />
                            </Button>

                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="{Binding BrowserLabel, StringFormat=Opens in: {0}}"
                                       TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Border>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding UsefulSitesStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

            <GroupBox Header="Remove Empty Directories" Margin="0,0,0,12">
              <StackPanel Margin="12">
                <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                           Text="Scan a folder tree for directories that are already empty or become empty after nested empty folders are removed. Review the checklist, then delete only the folders you want gone."
                           TextWrapping="Wrap" />

                <Grid Margin="0,12,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Grid.Column="0"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"
                             Text="Root" />
                  <TextBox Grid.Column="1"
                           Margin="0,0,8,0"
                           Text="{Binding EmptyDirectoryRootPath, UpdateSourceTrigger=PropertyChanged}" />
                  <Button Grid.Column="2"
                          Margin="0,0,8,0"
                          Padding="12,6"
                          Command="{Binding BrowseEmptyDirectoryRootCommand}"
                          Content="Browse" />
                  <Button Grid.Column="3"
                          Padding="12,6"
                          Command="{Binding OpenEmptyDirectoryRootCommand}"
                          Content="Open" />
                </Grid>

                <TextBlock Margin="0,8,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding EmptyDirectorySelectionSummary}" />

                <WrapPanel Margin="0,12,0,0"
                           HorizontalAlignment="Right">
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ScanEmptyDirectoriesCommand}"
                          Content="Scan Tree" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding SelectAllEmptyDirectoriesCommand}"
                          Content="Select All" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding ClearEmptyDirectorySelectionCommand}"
                          Content="Clear" />
                  <Button Margin="4"
                          Padding="12,6"
                          Command="{Binding DeleteSelectedEmptyDirectoriesCommand}"
                          Content="Delete Selected" />
                </WrapPanel>

                <Border Margin="0,12,0,0"
                        Padding="10"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEmptyDirectoryScanProgressVisible}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>

                  <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding EmptyDirectoryScanProgressSummary}"
                               TextWrapping="Wrap" />
                    <ProgressBar Margin="0,8,0,0"
                                 Height="14"
                                 Minimum="0"
                                 Maximum="{Binding EmptyDirectoryScanProgressMaximum}"
                                 Value="{Binding EmptyDirectoryScanProgressValue}" />
                  </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="8"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                  <ListBox MaxHeight="320"
                           ItemContainerStyle="{StaticResource VirtualizedCardListItemStyle}"
                           ItemsSource="{Binding EmptyDirectoryCandidates}"
                           Style="{StaticResource VirtualizedCardListStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,10"
                                  Padding="10"
                                  Background="{DynamicResource ControlBackgroundBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6">
                            <StackPanel>
                              <CheckBox IsChecked="{Binding IsSelected}">
                                <TextBlock FontWeight="SemiBold"
                                           Text="{Binding DisplayPath}" />
                              </CheckBox>

                              <TextBlock Margin="20,4,0,0"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         Text="{Binding HintText}"
                                         TextWrapping="Wrap" />

                              <TextBlock Margin="20,6,0,0"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Foreground="{DynamicResource MutedTextBrush}"
                                         Text="{Binding FullPath}"
                                         TextWrapping="Wrap" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>

                <TextBlock Margin="0,10,0,0"
                           Text="{Binding EmptyDirectoryStatusMessage}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </GroupBox>

              </StackPanel>
            </Expander>
          </StackPanel>
        </ScrollViewer>
</UserControl>

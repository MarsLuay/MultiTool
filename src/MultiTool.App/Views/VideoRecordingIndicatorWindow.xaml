<Window x:Class="MultiTool.App.Views.VideoRecordingIndicatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="112"
        Height="46"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False"
        ShowActivated="False"
        Opacity="0"
        IsHitTestVisible="False">
  <Border x:Name="BadgeBorder"
          Padding="10,6"
          Background="#D9151820"
          BorderBrush="#80FF5A5F"
          BorderThickness="1"
          CornerRadius="16">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
      <Ellipse Width="10" Height="10" Fill="#FFFF5A5F" Margin="0,0,8,0" />
      <Image x:Name="IconImage" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform" />
      <TextBlock VerticalAlignment="Center"
                 Foreground="White"
                 FontSize="13"
                 FontWeight="SemiBold"
                 Text="REC" />
    </StackPanel>
  </Border>
</Window>

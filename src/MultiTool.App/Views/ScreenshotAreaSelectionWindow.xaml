<Window x:Class="MultiTool.App.Views.ScreenshotAreaSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#22000000"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Arrow">
  <Canvas x:Name="RootCanvas">
    <Border x:Name="SelectionBorder"
            Visibility="Collapsed"
            BorderBrush="#FFFFC857"
            BorderThickness="2"
            Background="#33FFC857" />
    <Border Canvas.Left="24"
            Canvas.Top="24"
            Padding="12"
            Background="#CC101820"
            CornerRadius="8">
      <StackPanel>
        <TextBlock x:Name="AreaInstructionTextBlock" Foreground="White" FontSize="16" FontWeight="SemiBold" Text="" />
        <TextBlock x:Name="AreaInstructionHintTextBlock" Margin="0,4,0,0" Foreground="#FFD4D8DD" Text="" />
        <StackPanel x:Name="VideoOptionsPanel"
                    Margin="0,12,0,0"
                    Visibility="Collapsed">
          <Button x:Name="VideoChooseAreaButton"
                  Margin="0,0,0,8"
                  Padding="12,8"
                  Click="VideoChooseAreaButton_OnClick"
                  Content="" />
          <Button x:Name="VideoCurrentScreenButton"
                  Margin="0,0,0,8"
                  Padding="12,8"
                  Click="VideoCurrentScreenButton_OnClick"
                  Content="" />
          <Button x:Name="VideoAllScreensButton"
                  Padding="12,8"
                  Click="VideoAllScreensButton_OnClick"
                  Content="" />
        </StackPanel>
      </StackPanel>
    </Border>
  </Canvas>
</Window>

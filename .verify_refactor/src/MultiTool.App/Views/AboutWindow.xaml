<Window x:Class="MultiTool.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="340"
        Height="180"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="20">
    <StackPanel VerticalAlignment="Center">
      <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding AppNameText}" />
      <TextBlock Margin="0,8,0,0" Text="{Binding AboutSubtitleText}" TextWrapping="Wrap" />
      <TextBlock Margin="0,8,0,0" Text="{Binding VersionText}" />
      <Button Margin="0,16,0,0" Width="80" HorizontalAlignment="Right" Content="{Binding CloseButtonText}" Click="CloseButton_OnClick" />
    </StackPanel>
  </Grid>
</Window>

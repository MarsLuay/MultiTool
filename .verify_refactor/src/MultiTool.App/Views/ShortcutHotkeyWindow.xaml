<Window x:Class="MultiTool.App.Views.ShortcutHotkeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitleText}"
        Width="1120"
        Height="720"
        MinWidth="820"
        MinHeight="420"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <Style x:Key="CompactPrimaryCellTextStyle" TargetType="TextBlock">
      <Setter Property="TextWrapping" Value="NoWrap" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style x:Key="CompactSecondaryCellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CompactPrimaryCellTextStyle}">
      <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Margin" Value="0,2,0,0" />
      <Style.Triggers>
        <Trigger Property="Text" Value="">
          <Setter Property="Visibility" Value="Collapsed" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="ConflictCellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CompactPrimaryCellTextStyle}">
      <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding HasConflict}" Value="True">
          <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </DataTrigger>
        <Trigger Property="Text" Value="">
          <Setter Property="Visibility" Value="Collapsed" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="DataGrid">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceAltBrush}" />
      <Setter Property="AlternationCount" Value="2" />
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="RowHeaderWidth" Value="0" />
    </Style>
    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="8,6" />
    </Style>
    <Style TargetType="DataGridCell">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
          <Setter Property="Foreground" Value="{DynamicResource SelectionTextBrush}" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="DataGridRow">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="Height" Value="Auto" />
      <Setter Property="MinHeight" Value="42" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding HasConflict}" Value="True">
          <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        </DataTrigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
          <Setter Property="Foreground" Value="{DynamicResource SelectionTextBrush}" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Border Margin="12"
          Padding="16"
          Background="{DynamicResource SurfaceBrush}"
          BorderBrush="{DynamicResource BorderBrush}"
          BorderThickness="1"
          CornerRadius="8">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock FontSize="22"
                 FontWeight="SemiBold"
                 Text="{Binding HeadingText}" />

      <StackPanel Grid.Row="1" Margin="0,10,0,0">
        <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" />
        <TextBlock Margin="0,6,0,0"
                   Foreground="{DynamicResource AccentBrush}"
                   Text="{Binding WarningText}"
                   TextWrapping="Wrap">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <Trigger Property="Text" Value="">
                  <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
        <TextBlock Margin="0,6,0,0"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Text="{Binding ReferenceNoteText}"
                   TextWrapping="Wrap">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <Trigger Property="Text" Value="">
                  <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
        <TextBlock Margin="0,6,0,0"
                   Foreground="{DynamicResource AccentBrush}"
                   FontWeight="SemiBold"
                   Text="{Binding ConflictWarningText}"
                   TextWrapping="Wrap">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <Trigger Property="Text" Value="">
                  <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </StackPanel>

      <Grid Grid.Row="2" Margin="0,12,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Margin="0,0,8,0"
                   VerticalAlignment="Center"
                   Text="{Binding SearchLabelText}" />
        <TextBox Grid.Column="1"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        <CheckBox Grid.Column="2"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center"
                  Content="{Binding ConflictsOnlyText}"
                  IsChecked="{Binding ShowOnlyConflicts}" />
      </Grid>

      <DataGrid x:Name="ShortcutGrid"
                Grid.Row="3"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserResizeRows="False"
                EnableColumnVirtualization="True"
                EnableRowVirtualization="True"
                HeadersVisibility="Column"
                IsReadOnly="False"
                ItemsSource="{Binding ShortcutsView}"
                FrozenColumnCount="2"
                ScrollViewer.CanContentScroll="True"
                SelectionMode="Extended">
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="{Binding DataContext.ColumnHotkeyText, RelativeSource={RelativeSource AncestorType=Window}}"
                                  IsReadOnly="True"
                                  Width="132">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Style="{StaticResource CompactPrimaryCellTextStyle}"
                           Text="{Binding Hotkey}"
                           ToolTip="{Binding Hotkey}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridCheckBoxColumn Header="{Binding DataContext.ColumnEnabledText, RelativeSource={RelativeSource AncestorType=Window}}"
                                  Binding="{Binding IsShortcutEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Width="78">
            <DataGridCheckBoxColumn.ElementStyle>
              <Style TargetType="CheckBox">
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="IsEnabled" Value="{Binding CanEditShortcutEnabledState}" />
              </Style>
            </DataGridCheckBoxColumn.ElementStyle>
            <DataGridCheckBoxColumn.EditingElementStyle>
              <Style TargetType="CheckBox">
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="IsEnabled" Value="{Binding CanEditShortcutEnabledState}" />
              </Style>
            </DataGridCheckBoxColumn.EditingElementStyle>
          </DataGridCheckBoxColumn>
          <DataGridTemplateColumn Header="{Binding DataContext.ColumnShortcutText, RelativeSource={RelativeSource AncestorType=Window}}"
                                  IsReadOnly="True"
                                  Width="1.8*">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <StackPanel>
                  <TextBlock Style="{StaticResource CompactPrimaryCellTextStyle}"
                             Text="{Binding ShortcutName}"
                             ToolTip="{Binding ShortcutToolTip}" />
                  <TextBlock Style="{StaticResource CompactSecondaryCellTextStyle}"
                             Text="{Binding ShortcutSecondaryText}"
                             ToolTip="{Binding ShortcutToolTip}" />
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="{Binding DataContext.ColumnSourceText, RelativeSource={RelativeSource AncestorType=Window}}"
                                  IsReadOnly="True"
                                  Width="1.45*">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <StackPanel>
                  <TextBlock Style="{StaticResource CompactPrimaryCellTextStyle}"
                             Text="{Binding SourceLabel}"
                             ToolTip="{Binding SourceLabel}" />
                  <TextBlock Style="{StaticResource CompactSecondaryCellTextStyle}"
                             Text="{Binding SourceSecondaryText}"
                             ToolTip="{Binding AppliesTo}" />
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="{Binding DataContext.ColumnConflictText, RelativeSource={RelativeSource AncestorType=Window}}"
                                  IsReadOnly="True"
                                  Width="1.45*">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Style="{StaticResource ConflictCellTextStyle}"
                           Text="{Binding ConflictSummary}"
                           ToolTip="{Binding ConflictSummary}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="{Binding DataContext.ColumnFileText, RelativeSource={RelativeSource AncestorType=Window}}"
                                  IsReadOnly="True"
                                  Width="2.3*">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <StackPanel>
                  <TextBlock Style="{StaticResource CompactPrimaryCellTextStyle}"
                             Text="{Binding LocationPrimaryText}"
                             ToolTip="{Binding LocationToolTip}" />
                  <TextBlock Style="{StaticResource CompactSecondaryCellTextStyle}"
                             Text="{Binding LocationSecondaryText}"
                             ToolTip="{Binding LocationToolTip}" />
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>

      <DockPanel Grid.Row="4" Margin="0,12,0,0">
        <StackPanel DockPanel.Dock="Left">
          <TextBlock VerticalAlignment="Center"
                     Foreground="{DynamicResource MutedTextBrush}"
                     Text="{Binding FilterSummary}" />
          <TextBlock Margin="0,4,0,0"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource MutedTextBrush}"
                     Text="{Binding StatusText}"
                     TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <ProgressBar Width="92"
                       Height="14"
                       Margin="0,0,10,0"
                       IsIndeterminate="True">
            <ProgressBar.Style>
              <Style TargetType="ProgressBar">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ProgressBar.Style>
          </ProgressBar>

          <Button Width="88"
                  Margin="0,0,8,0"
                  Command="{Binding RescanCommand}"
                  Content="{Binding RescanButtonText}" />
          <Button Width="112"
                  Margin="0,0,8,0"
                  Command="{Binding ApplyShortcutChangesCommand}"
                  Content="{Binding ApplyChangesButtonText}" />
          <Button Width="88"
                  HorizontalAlignment="Right"
                  Content="{Binding CloseButtonText}"
                  Click="CloseButton_OnClick" />
        </StackPanel>
      </DockPanel>
    </Grid>
  </Border>
</Window>

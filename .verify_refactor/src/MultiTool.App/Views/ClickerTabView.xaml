<UserControl x:Class="MultiTool.App.Views.ClickerTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/MultiTool;component/Resources/MainWindowSharedResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>
<ScrollViewer DataContext="{Binding Shell}" VerticalScrollBarVisibility="Auto">
          <Grid Margin="0,12,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Click Setup" Margin="0,0,0,12">
              <Grid Margin="12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                  <TextBlock Margin="4,0,4,6"
                             FontWeight="SemiBold"
                             Text="{Binding IntervalLabelText}" />
                  <UniformGrid Columns="2">
                    <StackPanel Margin="4">
                      <TextBlock Margin="0,0,0,4" Text="{Binding HoursLabelText}" />
                      <TextBox Text="{Binding Hours, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="4">
                      <TextBlock Margin="0,0,0,4" Text="{Binding MinutesLabelText}" />
                      <TextBox Text="{Binding Minutes, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="4">
                      <TextBlock Margin="0,0,0,4" Text="{Binding SecondsLabelText}" />
                      <TextBox Text="{Binding Seconds, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="4">
                      <TextBlock Margin="0,0,0,4" Text="{Binding MillisecondsLabelText}" />
                      <TextBox Text="{Binding Milliseconds, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                  </UniformGrid>

                  <StackPanel Margin="4,10,4,0">
                    <CheckBox Content="{Binding RandomTimingLabelText}"
                              IsChecked="{Binding IsRandomTimingEnabled}" />
                    <StackPanel Margin="24,6,0,0"
                                Orientation="Horizontal">
                      <TextBlock VerticalAlignment="Center"
                                 Text="{Binding RandomTimingVarianceLabelText}" />
                      <TextBox Width="84"
                               Margin="8,0,0,0"
                               IsEnabled="{Binding IsRandomTimingVarianceEnabled}"
                               Text="{Binding RandomTimingVarianceMilliseconds, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <TextBlock Margin="24,6,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding RandomTimingHelperText}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2">
                  <TextBlock Margin="4,0,4,6"
                             FontWeight="SemiBold"
                             Text="{Binding RepeatLabelText}" />
                  <Grid Margin="4,0,4,10">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              Margin="0,0,8,0"
                              ItemsSource="{Binding RepeatModes}"
                              SelectedItem="{Binding SelectedRepeatMode}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox Grid.Column="1"
                             Style="{StaticResource RepeatCountTextBoxStyle}"
                             Width="72"
                             IsEnabled="{Binding IsRepeatCountEnabled}"
                             Text="{Binding RepeatCount, UpdateSourceTrigger=PropertyChanged}" />
                  </Grid>

                  <StackPanel IsEnabled="{Binding UsesMousePositionSettings}">
                    <TextBlock Margin="4,0,4,6"
                               FontWeight="SemiBold"
                               Text="{Binding PositionLabelText}" />
                    <Grid Margin="4,0,4,0">
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ComboBox Grid.Column="0"
                                Grid.Row="0"
                                Margin="0,0,8,0"
                                MinWidth="110"
                                ItemsSource="{Binding LocationModes}"
                                SelectedItem="{Binding SelectedLocationMode}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <Button Grid.Row="0" Grid.Column="1" Width="68" Command="{Binding CaptureCoordinatesCommand}" Content="{Binding CaptureButtonText}" />

                      <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0" Orientation="Horizontal">
                        <TextBlock Margin="0,0,4,0" VerticalAlignment="Center" Text="{Binding XLabelText}" />
                        <TextBox Width="64" Margin="0,0,12,0" Text="{Binding FixedX, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="0,0,4,0" VerticalAlignment="Center" Text="{Binding YLabelText}" />
                        <TextBox Width="64" Text="{Binding FixedY, UpdateSourceTrigger=PropertyChanged}" />
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </GroupBox>

            <GroupBox Grid.Row="1" Header="Click Options" Margin="0,0,0,12">
              <Grid Margin="12">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Margin="4" VerticalAlignment="Center" Text="{Binding InputLabelText}" />
                <ComboBox Grid.Row="0"
                          Grid.Column="1"
                          Margin="4"
                          ItemsSource="{Binding MouseButtons}"
                          SelectedItem="{Binding SelectedMouseButton}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="4" VerticalAlignment="Center" Text="{Binding TypeLabelText}" />
                <ComboBox Grid.Row="1"
                          Grid.Column="1"
                          Margin="4"
                          ItemsSource="{Binding ClickKinds}"
                          SelectedItem="{Binding SelectedClickKind}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Converter={StaticResource EnumDisplayNameConverter}}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="4" VerticalAlignment="Center" Text="{Binding CustomInputLabelText}" />
                <TextBox x:Name="CustomKeyTextBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="4"
                         IsReadOnly="True"
                         IsEnabled="{Binding IsCustomKeySelected}"
                         PreviewMouseDown="CustomInputTextBox_OnPreviewMouseDown"
                         PreviewKeyDown="CustomKeyTextBox_OnPreviewKeyDown"
                         Text="{Binding CustomKeyDisplayText}"
                         ToolTip="{Binding CustomKeyOrMousePromptText}" />
              </Grid>
            </GroupBox>

            <Grid Grid.Row="2">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0"
                         Margin="0,0,0,8"
                         VerticalAlignment="Center"
                         TextWrapping="Wrap"
                         Text="{Binding StatusMessage}" />

              <WrapPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Margin="4,0,8,0" VerticalAlignment="Center" Text="{Binding ClickerHotkeyLabelText}" />
                <ToggleButton x:Name="ClickerHotkeyTextBox"
                              Margin="4"
                              MinWidth="96"
                              Style="{StaticResource CaptureReadyButtonStyle}"
                              GotKeyboardFocus="ClickerHotkeyTextBox_OnGotKeyboardFocus"
                              LostKeyboardFocus="CaptureButton_OnLostKeyboardFocus"
                              PreviewMouseDown="ClickerHotkeyTextBox_OnPreviewMouseDown"
                              PreviewKeyDown="ClickerHotkeyTextBox_OnPreviewKeyDown"
                              Content="{Binding ClickerHotkeyDisplay}"
                              ToolTip="{Binding HotkeyEditToolTip}" />
              </WrapPanel>

              <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
                <CheckBox Margin="12,0,0,0" VerticalAlignment="Center" Content="{Binding AlwaysOnTopLabelText}" IsChecked="{Binding IsTopMost}" />
              </WrapPanel>

              <TextBlock Grid.Row="3"
                         Margin="0,10,0,0"
                         FontSize="11"
                         Foreground="{DynamicResource MutedTextBrush}"
                         Text="{Binding ClickerForceStopHelperText}"
                         TextAlignment="Center"
                         TextWrapping="Wrap" />
            </Grid>
          </Grid>
        </ScrollViewer>
</UserControl>
